FROM node:20-alpine AS builder
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
RUN npm run build

FROM node:20-alpine
WORKDIR /app
COPY package*.json ./
RUN npm ci --omit=dev
COPY --from=builder /app/dist ./dist
COPY --from=builder /app/vite.config.js ./
COPY --from=builder /app/scripts ./scripts
EXPOSE 8660
CMD ["npm", "run", "preview"]
